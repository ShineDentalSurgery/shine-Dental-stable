<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Receipts</title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f5f5f5;
            padding: 20px;
        }

        .admin-container {
            max-width: 1400px;
            margin: 0 auto;
            background: white;
            padding: 20px;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .admin-header h1 {
            font-size: 24px;
            color: #333;
        }

        .btn-create {
            background: #4CAF50;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-create:hover {
            background: #45a049;
        }

        .search-box {
            flex: 1;
            min-width: 250px;
        }

        .search-box input {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
        }

        .admin-content {
            padding: 0;
        }

        .table-wrapper {
            overflow-x: auto;
            border: 1px solid #ddd;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
        }

        thead {
            background: #f0f0f0;
        }

        th {
            padding: 12px;
            text-align: left;
            font-weight: bold;
            border-bottom: 1px solid #ddd;
            font-size: 13px;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            font-size: 13px;
        }

        tbody tr:hover {
            background: #f9f9f9;
        }

        .badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 3px;
            font-size: 12px;
            background: #e0e0e0;
            color: #333;
        }

        .badge-cash {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .badge-mobile {
            background: #e3f2fd;
            color: #1565c0;
        }

        .amount {
            font-weight: normal;
            color: #333;
        }

        .amount.negative {
            color: #d32f2f;
        }

        .amount.positive {
            color: #388e3c;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
        }

        .btn {
            display: inline-block;
            padding: 6px 10px;
            border: 1px solid #ddd;
            background: white;
            color: #333;
            cursor: pointer;
            font-size: 12px;
            text-decoration: none;
            border-radius: 3px;
        }

        .btn-delete {
            background: #ffebee;
            color: #d32f2f;
            border: 1px solid #d32f2f;
        }

        .btn-delete:hover {
            background: #d32f2f;
            color: white;
        }

        .btn-edit {
            background: #e3f2fd;
            color: #1976d2;
            border: 1px solid #1976d2;
        }

        .btn-edit:hover {
            background: #1976d2;
            color: white;
        }

        .btn-view {
            background: #2196F3;
            color: white;
            border: 1px solid #2196F3;
        }

        .btn-view:hover {
            background: #0b7dda;
            color: white;
        }

        .btn-icon {
            width: 32px;
            height: 32px;
            padding: 0 !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .no-data {
            text-align: center;
            padding: 40px;
            color: #999;
        }

        @media (max-width: 768px) {
            .admin-header {
                flex-direction: column;
                align-items: stretch;
            }

            th, td {
                padding: 8px;
                font-size: 12px;
            }

            .btn {
                padding: 4px 8px;
                font-size: 11px;
            }
        }
    </style>
</head>
<body>
    <div class="admin-container">
        <div class="admin-header">
            <h1>Admin Receipts</h1>
            <a href="/receipt" class="btn-create">
                <i class="fas fa-plus"></i> Create Receipt
            </a>
            <form class="search-box" method="GET" action="/receipts" style="display:flex; gap:8px; width:100%; max-width:480px;">
                <input type="text" name="search" id="searchInput" placeholder="Search by patient name, phone, or ID..." value="<%= search || '' %>" style="flex:1; padding:10px; border-radius:4px; border:1px solid #ced4da;">
                <button type="submit" class="btn" style="padding:10px 16px;">Search</button>
            </form>
        </div>

        <div class="admin-content">
            <% if (receipts && receipts.length > 0) { %>
                <div class="table-wrapper">
                    <table id="receiptsTable">
                        <thead>
                            <tr>
                                <th>Receipt ID</th>
                                <th>Date</th>
                                <th>Patient Name</th>
                                <th>Phone</th>
                                <th>Services</th>
                                <th>Total</th>
                                <th>Mode</th>
                                <th>Paid</th>
                                <th>Balance</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% receipts.forEach(receipt => { %>
                                <tr>
                                    <td>#<%= receipt.id %></td>
                                    <td><%= new Date(receipt.created_at).toLocaleDateString('en-GB') %></td>
                                    <td><%= receipt.patient_name %></td>
                                    <td><%= formatPhone(receipt.patient_phone) %></td>
                                    <td><%= formatService(receipt.service) %></td>
                                    <td>UGX <%= Number(receipt.total).toLocaleString('en-US') %></td>
                                    <td>
                                        <span class="badge <%= receipt.mode_of_payment === 'cash' ? 'badge-cash' : 'badge-mobile' %>">
                                            <%= receipt.mode_of_payment %>
                                        </span>
                                    </td>
                                    <td><%= Number(receipt.amount_paid).toLocaleString('en-US') %></td>
                                    <td class="<%= Number(receipt.balance) > 0 ? 'amount negative' : 'amount positive' %>">
                                        <%= Number(receipt.balance).toLocaleString('en-US') %>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <a href="/receipts/<%= receipt.id %>" class="btn btn-view btn-icon" title="View"><i class="fas fa-eye"></i></a>
                                            <a href="/receipts/edit/<%= receipt.id %>" class="btn btn-edit btn-icon" title="Edit"><i class="fas fa-edit"></i></a>
                                            <button class="btn btn-delete btn-icon" onclick="deleteReceipt('<%= receipt.id %>')" title="Delete"><i class="fas fa-trash"></i></button>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <% if (pagination && pagination.totalPages > 1) { %>
                    <div class="pagination">
                        <% if (pagination.hasPrevPage) { %>
                            <a class="btn" href="/receipts?page=<%= pagination.page - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>">← Previous</a>
                        <% } %>
                        <span>Page <%= pagination.page %> of <%= pagination.totalPages %></span>
                        <% if (pagination.hasNextPage) { %>
                            <a class="btn" href="/receipts?page=<%= pagination.page + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>">Next →</a>
                        <% } %>
                    </div>
                <% } %>
            <% } else { %>
                <div class="no-data">
                    <i class="fas fa-inbox"></i>
                    <p>No receipts found</p>
                </div>
            <% } %>
        </div>
    </div>

    <button id="scrollToBottomBtn" title="Scroll to bottom">↓</button>

    <script>
        // Delete receipt
        async function deleteReceipt(receiptId) {
            if (confirm("Are you sure you want to delete this receipt? This action cannot be undone.")) {
                try {
                    const response = await fetch(`/receipts/delete/${receiptId}`, {
                        method: 'DELETE'
                    });
                    const result = await response.json();
                    if (response.ok) {
                        alert(result.message);
                        location.reload();
                    } else {
                        alert(result.message || "Error deleting receipt");
                    }
                } catch (error) {
                    alert("Error deleting receipt");
                    console.error(error);
                }
            }
        }

        // Scroll to bottom button
        const scrollToBottomBtn = document.getElementById('scrollToBottomBtn');
        
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                scrollToBottomBtn.style.display = 'block';
            } else {
                scrollToBottomBtn.style.display = 'none';
            }
        });
        
        scrollToBottomBtn.addEventListener('click', () => {
            window.scrollTo({
                top: document.documentElement.scrollHeight,
                behavior: 'smooth'
            });
        });
    </script>

    <style>
        #scrollToBottomBtn {
            display: none;
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #333;
            color: white;
            border: none;
            border-radius: 4px;
            width: 40px;
            height: 40px;
            font-size: 18px;
            cursor: pointer;
            z-index: 1000;
        }

        #scrollToBottomBtn:hover {
            background: #555;
        }

        .pagination {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-top: 20px;
        }

        .pagination span {
            color: #333;
            font-weight: 600;
        }

        .pagination .btn {
            min-width: 100px;
            text-align: center;
        }
    </style>