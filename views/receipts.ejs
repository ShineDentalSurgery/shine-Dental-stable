<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        .hidden {
            display: none;
        }

        .pagination {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin: 16px 0;
            font-family: Arial, sans-serif;
        }

        .pagination .page-link {
            display: inline-block;
            padding: 8px 14px;
            border-radius: 4px;
            border: 1px solid #ccc;
            background: #fff;
            color: #333;
            text-decoration: none;
            transition: background 0.2s ease;
        }

        .pagination .page-link:hover {
            background: #f0f0f0;
        }

        .pagination .page-info {
            font-weight: 600;
            color: #333;
        }

        .balance-negative {
            color: #dc3545;
        }

        .balance-positive {
            color: #28a745;
        }

        /* Scroll to bottom button */
        #scrollToBottomBtn {
            display: none;
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #589f14;
            color: white;
            border: none;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            font-size: 24px;
            cursor: pointer;
            z-index: 1000;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
        }

        #scrollToBottomBtn:hover {
            background: #4a7c0e;
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
            transform: scale(1.1);
        }

        #scrollToBottomBtn:active {
            transform: scale(0.95);
        }
    </style>
</head>

<body>
    <div class="table">


        <div class="table-specs">


            <h2>
                <%= title %>
            </h2>
            <form method="GET" action="/receipts" style="margin-bottom: 15px; align-items:center;">
                <input type="text" name="search" id="filter" placeholder="Search patient name, phone, or ID..."
                    value="<%= typeof search !== 'undefined' ? search : '' %>"
                    style="padding: 10px; border-radius: 4px; border: 1px solid #ccc; min-width: 240px; width: 100%; max-width: 400px;">
                <button type="submit"
                    style="padding: 10px 16px; border-radius: 4px; border: none; background:#589f14; color:white; cursor:pointer;">Search</button>
                <a href="/receipt"
                    style="margin-bottom: 15px; padding: 10px 20px; background-color: #589f14; color: white; text-decoration: none; border-radius: 4px; display: inline-block;">+
                    New Receipt</a>
            </form>
            <table>
                <thead>
                    <tr>
                        <th>Receipt ID</th>
                        <th>Date</th>
                        <th>Patient Name</th>
                        <th>Phone Number</th>
                        <th>Amount Paid</th>
                        <th>Mode of Payment</th>
                        <th>Balance</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% receipts.forEach(receipt=> { %>
                        <tr class="item-list">
                            <td>
                                <%= receipt.id %>
                            </td>
                            <td>
                                <%= new Date(receipt.created_at).toLocaleDateString('en-GB') %>
                            </td>
                            <td class="names"> <a href="/receiptDetails/<%= receipt.id %>?patient_id=<%= receipt.id %>">
                                    <%= receipt.patient_name %>
                                </a> </td>
                            <td>
                                <a href="https://wa.me/<%= receipt.patient_phone.replace(/\D/g, '') %>?text=<%= encodeURIComponent(`Hello ${receipt.patient_name}, thank you for choosing Shine Dental Surgery. Call/WhatsApp us on: +256702608900 | +256705026289`) %>"
                                    target="_blank" style="color: #25D366; text-decoration: none;"
                                    title="Send WhatsApp message">

                                    Tel: <%= formatPhone(receipt.patient_phone) %>

                                        <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg"
                                            alt="WhatsApp" style="height:16px;vertical-align:middle;margin-left:4px;">
                                </a>
                            </td>
                            <td><span style="color: #000000; font-weight: bold;">
                                    UGX <%= Number(receipt.amount_paid).toLocaleString('en-US') %>
                                </span></td>
                            <td>
                                <%= receipt.mode_of_payment %>
                            </td>
                            <td><span
                                    class="<%= Number(receipt.balance) > 0 ? 'balance-negative' : 'balance-positive' %>"
                                    style="font-weight: bold;">
                                    UGX <%= Number(receipt.balance).toLocaleString('en-US') %>
                                </span>
                            </td>
                            <td>
                                <% if (user && user.usertype==='admin' ) { %>
                                    <button onclick="deleteReceipt('<%= receipt.id %>')"
                                        style="color: white;">Delete</button>
                                    <% } %>
                                        <a href="/receipts/patient/<%= encodeURIComponent(receipt.patient_name) %>"
                                            style="margin-left: 5px; padding: 5px 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 3px; display: inline-block;">
                                            View Patient
                                        </a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
            <% if (pagination && pagination.totalPages> 1) { %>
                <div class="pagination">
                    <% if (pagination.hasPrevPage) { %>
                        <a class="page-link"
                            href="/receipts?page=<%= pagination.page - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>">←
                            Previous</a>
                        <% } %>
                            <span class="page-info">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
                            <% if (pagination.hasNextPage) { %>
                                <a class="page-link"
                                    href="/receipts?page=<%= pagination.page + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>">Next
                                    →</a>
                                <% } %>
                </div>
                <% } %>
        </div>
    </div>
    <script>
        function formatPhoneNumber(phoneNumber) {
            // Remove all non-digit characters
            const cleanPhone = phoneNumber.replace(/\D/g, '');

            // If already starts with 256, return as is
            if (cleanPhone.startsWith('256')) {
                return cleanPhone;
            }

            // If starts with 0, remove 0 and add 256 prefix
            if (cleanPhone.startsWith('0')) {
                return '256' + cleanPhone.slice(1);
            }

            // For any other number, add 256 prefix
            return '256' + cleanPhone;
        }

        async function deleteReceipt(receiptId) {
            if (confirm("Are you sure you want to delete this receipt?")) {
                try {
                    const response = await fetch(`/receipts/delete/${receiptId}`, {
                        method: 'DELETE'
                    });
                    const result = await response.json();
                    if (response.ok) {
                        alert(result.message);
                        location.reload();
                    } else {
                        alert(result.message || "Error deleting receipt");
                    }
                } catch (error) {
                    alert("Error deleting receipt");
                }
            }
        }

        // Example usage for formatting phone numbers
        document.querySelectorAll(".patient-phone").forEach(phoneElement => {
            const formattedNumber = formatPhoneNumber(phoneElement.textContent.trim());
            phoneElement.textContent = formattedNumber;
        });
    </script>

    <button id="scrollToBottomBtn" title="Scroll to bottom">↓</button>

    <script>
        const scrollToBottomBtn = document.getElementById('scrollToBottomBtn');

        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                scrollToBottomBtn.style.display = 'block';
            } else {
                scrollToBottomBtn.style.display = 'none';
            }
        });

        scrollToBottomBtn.addEventListener('click', () => {
            window.scrollTo({
                top: document.documentElement.scrollHeight,
                behavior: 'smooth'
            });
        });
    </script>
</body>

</html>