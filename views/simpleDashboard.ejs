<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .dashboard-simple {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px;
    }

    .dashboard-header {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 3px solid #667eea;
    }

    .dashboard-header h1 {
        font-size: 32px;
        font-weight: 700;
        color: #333;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .dashboard-header p {
        margin: 0;
        color: #666;
        font-size: 14px;
    }

    /* KPI Cards Section */
    .kpi-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 40px;
    }

    .kpi-card {
        flex: 1;
        min-width: 200px;
        max-width: 280px;
        background: white;
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        border-left: 5px solid #667eea;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }

    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 60px;
        height: 60px;
        background: rgba(102, 126, 234, 0.05);
        border-radius: 50%;
        transform: translate(20px, -20px);
    }

    .kpi-card.sales {
        border-left-color: #28a745;
    }

    .kpi-card.sales .kpi-icon {
        color: #28a745;
    }

    .kpi-card.expenses {
        border-left-color: #dc3545;
    }

    .kpi-card.expenses .kpi-icon {
        color: #dc3545;
    }

    .kpi-card.balance {
        border-left-color: #ffc107;
    }

    .kpi-card.balance .kpi-icon {
        color: #ffc107;
    }

    .kpi-card.paid {
        border-left-color: #17a2b8;
    }

    .kpi-card.paid .kpi-icon {
        color: #17a2b8;
    }

    .kpi-icon {
        font-size: 32px;
        margin-bottom: 12px;
        opacity: 0.9;
        position: relative;
        z-index: 1;
    }

    .kpi-label {
        font-size: 12px;
        font-weight: 600;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        position: relative;
        z-index: 1;
    }

    .kpi-value {
        font-size: 28px;
        font-weight: 700;
        color: #333;
        margin-bottom: 4px;
        position: relative;
        z-index: 1;
    }

    .kpi-currency {
        font-size: 11px;
        color: #bbb;
        position: relative;
        z-index: 1;
    }

    /* Dashboard Grid */
    .dash-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    .dash-card {
        flex: 1;
        min-width: 300px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .dash-card:hover {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        transform: translateY(-2px);
    }

    .card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px;
        background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
        border-bottom: 2px solid #e9ecef;
    }

    .card-head h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
        color: #333;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .stat {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: #667eea;
        color: white;
        border-radius: 50%;
        font-weight: 700;
        font-size: 18px;
    }

    .card-body {
        padding: 20px;
    }

    .card-actions {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
    }

    .btn {
        padding: 10px 16px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: #dc3545;
        color: white;
    }

    .btn-primary:hover {
        background: #764ba2;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .btn-outline {
        background: transparent;
        color: #667eea;
        border: 1px solid #667eea;
    }

    .btn-outline:hover {
        background: #667eea;
        color: white;
    }

    .recent-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .recent-list li {
        padding: 10px;
        background: #f8f9fa;
        border-radius: 6px;
        border-left: 3px solid #667eea;
        transition: all 0.3s ease;
    }

    .recent-list li:hover {
        background: #f0f2f5;
        transform: translateX(4px);
    }

    .recent-list a {
        text-decoration: none;
        color: #333;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 500;
    }

    .recent-list i {
        color: #28a745;
    }

    .muted {
        color: #999;
        font-size: 13px;
        font-style: italic;
        text-align: center;
        padding: 20px;
        margin: 0;
    }

    @media (max-width: 768px) {
        .kpi-grid {
            flex-direction: column;
        }

        .kpi-card {
            max-width: 100%;
        }

        .dash-grid {
            flex-direction: column;
        }

        .dashboard-header h1 {
            font-size: 24px;
        }

        .card-actions {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<section class="dashboard-simple">
    <div class="dashboard-header">
        <h1><i class="fas fa-gauge-high"></i> Dashboard</h1>
        <p>Today's Summary — <%= new Date().toLocaleDateString('en-US', {weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'}) %></p>
    </div>

    <!-- KPI Cards Section -->
    <div class="kpi-grid">
        <!-- Daily Sales -->
        <div class="kpi-card sales">
            <div class="kpi-icon"><i class="fas fa-coins"></i></div>
            <div class="kpi-label">Daily Sales</div>
            <div class="kpi-value"><%= (dailySales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
            <div class="kpi-currency">UGX</div>
        </div>

        <!-- Daily Expenses -->
        <div class="kpi-card expenses">
            <div class="kpi-icon"><i class="fas fa-arrow-down"></i></div>
            <div class="kpi-label">Daily Expenses</div>
            <div class="kpi-value"><%= (dailyExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
            <div class="kpi-currency">UGX</div>
        </div>

        <!-- Net Balance -->
        <div class="kpi-card balance">
            <div class="kpi-icon"><i class="fas fa-wallet"></i></div>
            <div class="kpi-label">Net Balance</div>
            <div class="kpi-value"><%= ((dailySales || 0) - (dailyExpenses || 0)).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
            <div class="kpi-currency">UGX</div>
        </div>

        <!-- Paid Sales -->
        <div class="kpi-card paid">
            <div class="kpi-icon"><i class="fas fa-check-circle"></i></div>
            <div class="kpi-label">Fully Paid</div>
            <div class="kpi-value"><%= (paidSalesCount || 0) %></div>
            <div class="kpi-currency">transactions</div>
        </div>

        <!-- Outstanding Balance -->
        <div class="kpi-card paid">
            <div class="kpi-icon"><i class="fas fa-exclamation-circle"></i></div>
            <div class="kpi-label">Outstanding</div>
            <div class="kpi-value"><%= (outstandingAmount || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
            <div class="kpi-currency">UGX</div>
        </div>
    </div>

    <!-- Main Content Cards -->
    <div class="dash-grid">
        <!-- Appointments Section -->
        <div class="dash-card">
            <div class="card-head">
                <h3><i class="fas fa-calendar-check"></i> Upcoming Appointments</h3>
                <span class="stat"><%= upcomingAppointments && upcomingAppointments.length ? upcomingAppointments.length : 0 %></span>
            </div>

            <div class="card-body">
                <% if (upcomingAppointments && upcomingAppointments.length > 0) { %>
                    <ul class="recent-list">
                        <% upcomingAppointments.slice(0, 5).forEach(function(a){ %>
                            <li style="border-left-color: <%= a.days_until_visit === 0 ? '#dc3545' : a.days_until_visit === 1 ? '#ffc107' : '#28a745' %>;">
                                <a href="/appointments" style="display: flex; align-items: center; justify-content: space-between;">
                                    <span><i class="fas fa-circle-check"></i> <%= a.patient_name %></span>
                                    <span style="font-size: 11px; color: #999;">
                                        <% if (a.days_until_visit === 0) { %>
                                            TODAY
                                        <% } else if (a.days_until_visit === 1) { %>
                                            Tomorrow
                                        <% } else { %>
                                            <%= a.days_until_visit %> days
                                        <% } %>
                                    </span>
                                </a>
                            </li>
                        <% }) %>
                    </ul>
                    <% if (upcomingAppointments.length > 5) { %>
                        <a href="/appointments" class="btn btn-primary" style="width: 100%; justify-content: center; margin-top: 10px;">
                            <i class="fas fa-arrow-right"></i> View All (<%= upcomingAppointments.length %>)
                        </a>
                    <% } %>
                <% } else { %>
                    <p class="muted">No appointments in the next 7 days</p>
                <% } %>
            </div>
        </div>

        <div class="dash-card">
            <div class="card-head">
                <h3><i class="fas fa-receipt"></i> Receipts</h3>
                <span class="stat"><%= receiptsCount %></span>
            </div>

            <div class="card-body">
                <div class="card-actions">
                    <a href="/receipts" class="btn btn-outline"><i class="fas fa-list"></i> View All</a>
                    <a href="/receipt" class="btn btn-primary"><i class="fas fa-plus-circle"></i> New</a>
                </div>

                <% if (recentReceipts && recentReceipts.length) { %>
                    <ul class="recent-list">
                        <% recentReceipts.forEach(function(r){ %>
                            <li><a href="/receipts/<%= r.id %>"><i class="fas fa-circle-check"></i> <%= r.patient_name %> — UGX <%= parseFloat(r.total).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></a></li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p class="muted">No receipts today</p>
                <% } %>
            </div>
        </div>

        <div class="dash-card">
            <div class="card-head">
                <h3><i class="fas fa-file-invoice-dollar"></i> Invoices</h3>
                <span class="stat"><%= invoicesCount %></span>
            </div>

            <div class="card-body">
                <div class="card-actions">
                    <a href="/invoices" class="btn btn-outline"><i class="fas fa-list"></i> View All</a>
                    <a href="/invoices/new" class="btn btn-primary"><i class="fas fa-plus-circle"></i> New</a>
                </div>

                <% if (recentInvoices && recentInvoices.length) { %>
                    <ul class="recent-list">
                        <% recentInvoices.forEach(function(i){ %>
                            <li><a href="/invoices/<%= i.id %>"><i class="fas fa-circle-check"></i> <%= i.client_name || i.invoice_number %> — UGX <%= parseFloat(i.total).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></a></li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p class="muted">No invoices today</p>
                <% } %>
            </div>
        </div>

        <div class="dash-card">
            <div class="card-head">
                <h3><i class="fas fa-chart-line"></i> Quick Actions</h3>
                <span class="stat"><i class="fas fa-arrow-right"></i></span>
            </div>

            <div class="card-body">
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <a href="/receipt" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        <i class="fas fa-plus-circle"></i> New Receipt
                    </a>
                    <a href="/invoices/new" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        <i class="fas fa-plus-circle"></i> New Invoice
                    </a>
                    <a href="/treatment-note" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        <i class="fas fa-plus-circle"></i> Medical Form
                    </a>
                    <a href="/blank" class="btn btn-primary" style="width: 100%; justify-content: center;">
                        <i class="fas fa-plus-circle"></i> Blank Template
                    </a>
                    <a href="/appointments" class="btn btn-outline" style="width: 100%; justify-content: center;">
                        <i class="fas fa-calendar"></i> View Appointments
                    </a>
                    <a href="/expenses" class="btn btn-outline" style="width: 100%; justify-content: center;">
                        <i class="fas fa-money-bill-wave"></i> Manage Expenses
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>