<div class="error-container" style="padding: 40px; text-align: center; margin-top: 40px;">
    <div style="background-color: #f8d7da; border: 1px solid #f5c6cb; border-radius: 4px; padding: 20px; max-width: 500px; margin: 0 auto;">
        <h2 style="color: #721c24; margin-top: 0;">Error</h2>
        <p style="color: #721c24; font-size: 16px;">
            <%= message %>
        </p>
        <a href="/" style="display: inline-block; margin-top: 20px; padding: 10px 20px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px;">
            Return to Home
        </a>
    </div>
</div>
