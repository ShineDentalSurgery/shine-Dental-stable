<style>
    body {
        font-family: Arial;
    }

    .receipt {
        width: 700px;
        height: 210mm;
        margin: auto;
        padding: 20px;
        background-image: url('/images/shinedental-water_mark.png');
        background-repeat: no-repeat;
        background-position: center;
        background-size: 350px;
    }

    h1 {
        text-align: center;
        font-size: 18px;
        margin-bottom: 10px;
    }

    #amount-in-words {
        font-style: italic;
        display: inline;
        margin-top: 5px;
    }

    .patient-info span {
        display: block;
        font-size: 14px;
    }

    .fist-text {
        display: flex;
        justify-content: space-between;
        flex-direction: row-reverse;
        margin-top: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    table,
    th,
    td {
        border: 1px solid black;
    }

    th,
    td {
        padding: 6px;
        font-size: 13px;
    }

    .total-row td {
        font-weight: bold;
    }

    .summary-box {
        width: 250px;
        margin-top: 10px;
        float: right;
    }

    .summary-box td {
        border: 1px solid black;
    }

    .footer {
        margin-top: 30px;
    }

    .thank {
        margin-top: 60px;
        font-style: italic;
        text-align: center;
    }

    .buttons {
        /* align-items: center; */
        /* margin-left: 60px; */
        display: flex;
        justify-content: center;
        gap: 30px;
    }

    @media print {

        body {
            margin: 0;
            /* background-color: white; */
        }

        .receipt {
            height: 750px;
            width: 100%;
            margin-top: 0;
            margin-bottom: 0;
            background-image: url('/images/shinedental-water_mark.png');
            background-repeat: no-repeat;
            background-position: center;
            background-size: 450px;

        }

        button {
            display: none;
        }

        p.copyright {
            position: fixed;
            font-style: italic;
            color: #adaeaf;
            bottom: 10px;
            width: 100%;
            text-align: center;
            font-size: 12px;
        }

    }
</style>


<div class="receipt">

    <img src="/images/reciept_logo.png" width="120">

    <h1>Payment Receipt</h1>

    <div class="patient-info">

        <div class="fist-text">



            <div class="text-right">
                <span><strong>Receipt Number:</strong>
                    <strong style="color: red;"> 0<%= receipt.id %></strong>
                </span>

                <span><strong>Patient Number:</strong> <strong><%= formatPatientId(receipt.patient_id) %></strong></span>
            </div>


            <div class="text-left">
                <span><strong>Patient Name:</strong>
                    <%= receipt.patient_name %>
                </span>

                <span><strong>Tel:</strong>
                    <%= receipt.patient_phone %>
                </span>

                <span><strong>Date:</strong>
                    <%= new Date(receipt.created_at).toLocaleDateString('en-GB') %>
                </span>

                <% if (receipt.next_visit) { %>
                <span><strong>Next Visit:</strong>
                    <%= new Date(receipt.next_visit).toLocaleDateString('en-GB') %>
                </span>
                <% } %>
            </div>
        </div>

        <table>

            <thead>
                <tr>
                    <th>Service</th>
                    <th>Mode of Payment</th>
                    <th>Qty</th>
                    <!-- <th>Discount</th> -->
                    <th>Amount</th>
                </tr>
            </thead>

            <tbody>

                <% let services=[]; try { if (typeof receipt.service==='string' ) { const
                    parsed=JSON.parse(receipt.service); services=Array.isArray(parsed) ? parsed : [parsed]; } else if
                    (Array.isArray(receipt.service)) { services=receipt.service; } else if (receipt.service) {
                    services=[receipt.service]; } } catch (e) { services=receipt.service ? [receipt.service] : []; } %>


                    <% services.forEach(function(item){ %>

                        <tr>

                            <td>
                                <%= typeof item === 'object' ? (item.name || item.service || JSON.stringify(item)) : item %>
                            </td>

                            <td>
                                <%= receipt.mode_of_payment %>
                            </td>

                            <td>
                                <%= item.qty || 1 %>
                            </td>

                            <!-- <td>UGX <%= item.discount || 0 %></td> -->

                            <td>UGX <%= item.amount || receipt.total %>
                            </td>

                        </tr>

                        <% }) %>


                            <tr class="total-row">

                                <td colspan="3" style="text-align:right">Total Amount</td>

                                <td>UGX <%= receipt.total || receipt.total_amount %>
                                </td>

                            </tr>

            </tbody>

        </table>


        <br>

        <div>

            <strong>Amount Paid in Words:</strong>

            <span id="amount-in-words"></span>

        </div>


        <br>

        <table class="summary-box">

            <tr>
                <td><strong>Amount Paid</strong></td>
                <td style="text-align:right">UGX <%= Number(receipt.amount_paid || 0).toLocaleString('en-US') %>
                </td>
            </tr>

            <tr>
                <td><strong>Balance</strong></td>
                <td style="text-align:right">UGX <%= Number(receipt.balance || 0).toLocaleString('en-US') %>
                </td>
            </tr>

        </table>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>
        <br>

        <div class="footer">

            <p><strong>Served By:</strong>
                <%= servedBy || (user && (user.name || user.email || user.username)) || '_________' %>
            </p>
        </div>


        <div class="thank">

            Thank you for choosing Shine Dental Surgery


            <p class="copyright">© Shine Dental Surgery <%= new Date().getFullYear() %></p>

        </div>

        <div class="water-mark">
            <!-- watermark area - footer printed below -->
        </div>

    </div>

    <div class="buttons">
        <button onclick="window.print()">Print</button>
        <a href="/receipts"><button>Back</button></a>
    </div>





    <script>

        function numberToWords(num) {

            const a = ['', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine', 'ten', 'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen', 'seventeen', 'eighteen', 'nineteen'];

            const b = ['', '', 'twenty', 'thirty', 'forty', 'fifty', 'sixty', 'seventy', 'eighty', 'ninety'];

            function convert(n) {

                if (n < 20) return a[n];

                if (n < 100) return b[Math.floor(n / 10)] + (n % 10 ? '-' + a[n % 10] : '');

                if (n < 1000) return a[Math.floor(n / 100)] + ' hundred ' + convert(n % 100);

                if (n < 1000000) return convert(Math.floor(n / 1000)) + ' thousand ' + convert(n % 1000);

                return '';
            }

            return convert(num);
        }

        const totalAmount = Math.round(Number(<%= receipt.amount_paid || receipt.amount_paid || 0 %>) || 0);

        function numberToWordsFull(num) {
            if (num === 0) return 'zero';
            const a = ['', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine', 'ten', 'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen', 'seventeen', 'eighteen', 'nineteen'];
            const b = ['', '', 'twenty', 'thirty', 'forty', 'fifty', 'sixty', 'seventy', 'eighty', 'ninety'];
            const scales = ['', 'thousand', 'million', 'billion', 'trillion'];

            function chunkToWords(n) {
                let str = '';
                if (n >= 100) {
                    str += a[Math.floor(n / 100)] + ' hundred';
                    n = n % 100;
                    if (n) str += ' and ';
                }
                if (n >= 20) {
                    str += b[Math.floor(n / 10)];
                    if (n % 10) str += '-' + a[n % 10];
                } else if (n > 0) {
                    str += a[n];
                }
                return str;
            }

            let words = [];
            let scale = 0;
            let n = num;

            while (n > 0) {
                const chunk = n % 1000;
                if (chunk) {
                    const chunkWords = chunkToWords(chunk) + (scales[scale] ? ' ' + scales[scale] : '');
                    words.unshift(chunkWords.trim());
                }
                n = Math.floor(n / 1000);
                scale++;
            }

            return words.join(', ').replace(/, (?=[^,]*$)/, ' and ');
        }

        const words = numberToWordsFull(totalAmount);
        document.getElementById('amount-in-words').innerText = words.charAt(0).toUpperCase() + words.slice(1) + ' shillings';

    </script>

