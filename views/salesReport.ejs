<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    .sales-report-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 30px 20px;
    }

    .report-header {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 3px solid #667eea;
    }

    .report-header h1 {
        font-size: 32px;
        font-weight: 700;
        color: #333;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .report-header p {
        margin: 0;
        color: #666;
        font-size: 14px;
    }

    .report-nav {
        display: flex;
        gap: 12px;
        margin-bottom: 30px;
        flex-wrap: wrap;
        justify-content: flex-start;
    }

    .nav-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border: 2px solid #e0e0e0;
        background: white;
        border-radius: 6px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        color: #555;
        transition: all 0.3s ease;
    }

    .nav-btn:hover {
        border-color: #667eea;
        color: #667eea;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(102, 126, 234, 0.15);
    }

    .nav-btn.active {
        background: #667eea;
        color: white;
        border-color: #667eea;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .filter-section {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: center;
        background: linear-gradient(135deg, #f8f9fa 0%, #f0f2f5 100%);
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 30px;
        border-left: 4px solid #667eea;
    }

    .filter-section label {
        font-weight: 600;
        color: #333;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
    }

    .filter-section input,
    .filter-section select {
        padding: 10px 14px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 14px;
        transition: border-color 0.3s ease;
    }

    .filter-section input:focus,
    .filter-section select:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .filter-section button {
        padding: 10px 24px;
        background-color: #667eea;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .filter-section button:hover {
        background-color: #764ba2;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(102, 126, 234, 0.3);
    }

    .metrics-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 40px;
    }

    .metric-card {
        flex: 1;
        min-width: 200px;
        max-width: 280px;
        background: white;
        padding: 24px;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        border-left: 5px solid #667eea;
        display: flex;
        flex-direction: column;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .metric-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }

    .metric-card::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        width: 60px;
        height: 60px;
        background: rgba(102, 126, 234, 0.05);
        border-radius: 50%;
        transform: translate(20px, -20px);
    }

    .metric-icon {
        font-size: 32px;
        margin-bottom: 12px;
        opacity: 0.8;
        position: relative;
        z-index: 1;
    }

    .metric-card.cash { border-left-color: #28a745; }
    .metric-card.cash .metric-icon { color: #28a745; }
    
    .metric-card.visa { border-left-color: #ffc107; }
    .metric-card.visa .metric-icon { color: #ffc107; }
    
    .metric-card.mobile { border-left-color: #17a2b8; }
    .metric-card.mobile .metric-icon { color: #17a2b8; }
    
    .metric-card.balance { border-left-color: #fd7e14; }
    .metric-card.balance .metric-icon { color: #fd7e14; }
    
    .metric-card.expense { border-left-color: #dc3545; }
    .metric-card.expense .metric-icon { color: #dc3545; }
    
    .metric-card.before { border-left-color: #667eea; }
    .metric-card.before .metric-icon { color: #667eea; }
    
    .metric-card.after { border-left-color: #28a745; }
    .metric-card.after .metric-icon { color: #28a745; }

    .metric-label {
        font-size: 12px;
        font-weight: 600;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        position: relative;
        z-index: 1;
    }

    .metric-value {
        font-size: 28px;
        font-weight: 700;
        color: #333;
        word-break: break-word;
        position: relative;
        z-index: 1;
        margin-bottom: 6px;
    }

    .metric-currency {
        font-size: 11px;
        color: #bbb;
        position: relative;
        z-index: 1;
    }

    .report-section {
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
        margin-bottom: 30px;
        overflow-x: auto;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid #f0f0f0;
    }

    .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #333;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .section-title i {
        color: #667eea;
        font-size: 20px;
    }

    .breakdown-table {
        width: 100%;
        border-collapse: collapse;
    }

    .breakdown-table thead {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .breakdown-table th {
        padding: 14px;
        text-align: right;
        font-weight: 600;
        color: #333;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .breakdown-table th:first-child {
        text-align: left;
    }

    .breakdown-table td {
        padding: 14px;
        border-bottom: 1px solid #dee2e6;
        text-align: right;
        font-size: 14px;
    }

    .breakdown-table td:first-child {
        text-align: left;
        font-weight: 500;
        color: #333;
    }

    .breakdown-table tbody tr:hover {
        background-color: #f8f9fa;
    }

    .expense-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .expense-item {
        background: #f8f9fa;
        padding: 16px;
        border-radius: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-left: 4px solid #667eea;
        transition: all 0.3s ease;
    }

    .expense-item:hover {
        background: #f0f2f5;
        transform: translateX(4px);
    }

    .expense-item-content {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
    }

    .expense-icon {
        font-size: 18px;
        color: #667eea;
        min-width: 24px;
        text-align: center;
    }

    .expense-details {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .expense-description {
        font-weight: 600;
        color: #333;
        font-size: 14px;
    }

    .expense-category {
        display: inline-block;
        padding: 4px 10px;
        background: #e2e3e5;
        border-radius: 14px;
        font-size: 11px;
        font-weight: 600;
        color: #495057;
        width: fit-content;
    }

    .expense-amount {
        font-weight: 700;
        color: #dc3545;
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .no-data {
        text-align: center;
        padding: 40px 20px;
        color: #999;
        font-style: italic;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .no-data i {
        font-size: 48px;
        color: #ddd;
        margin-bottom: 10px;
    }

    @media (max-width: 768px) {
        .metrics-grid {
            flex-direction: column;
        }

        .metric-card {
            max-width: 100%;
        }

        .filter-section {
            flex-direction: column;
            align-items: flex-start;
        }

        .report-nav {
            justify-content: center;
        }

        .section-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="sales-report-container">
    <div class="report-header">
        <h1><i class="fas fa-chart-line"></i> Sales & Financial Report</h1>
        <p>Track daily, weekly, monthly, and annual sales broken down by payment method</p>
    </div>

    <!-- Navigation Buttons -->
    <div class="report-nav">
        <a href="/sales-report/daily" class="nav-btn <%= reportType === 'daily' ? 'active' : '' %>">
            <i class="fas fa-calendar-day"></i> Daily
        </a>
        <a href="/sales-report/weekly" class="nav-btn <%= reportType === 'weekly' ? 'active' : '' %>">
            <i class="fas fa-calendar-week"></i> Weekly
        </a>
        <% if (user && user.usertype === 'admin') { %>
        <a href="/sales-report/monthly" class="nav-btn <%= reportType === 'monthly' ? 'active' : '' %>">
            <i class="fas fa-calendar-alt"></i> Monthly
        </a>
        <a href="/sales-report/annual" class="nav-btn <%= reportType === 'annual' ? 'active' : '' %>">
            <i class="fas fa-calendar"></i> Annual
        </a>
        <% } %>
    </div>

    <!-- Navigation Buttons -->
    <!-- <div class="report-nav">
        <a href="/sales-report/daily" class="nav-btn <%= reportType === 'daily' ? 'active' : '' %>">Daily</a>
        <a href="/sales-report/weekly" class="nav-btn <%= reportType === 'weekly' ? 'active' : '' %>">Weekly</a>
        <a href="/sales-report/monthly" class="nav-btn <%= reportType === 'monthly' ? 'active' : '' %>">Monthly</a>
        <a href="/sales-report/annual" class="nav-btn <%= reportType === 'annual' ? 'active' : '' %>">Annual</a>
    </div> -->

    <!-- DAILY REPORT -->
    <% if (reportType === 'daily') { %>
        <div class="filter-section">
            <label><i class="fas fa-calendar-check"></i> Select Date:</label>
            <input type="date" value="<%= selectedDate %>" onchange="window.location.href='/sales-report/daily?date=' + this.value;">
            <span style="color: #666; font-size: 14px;">
                <%= new Date(selectedDate).toLocaleDateString('en-US', {weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'}) %>
            </span>
        </div>

        <!-- Key Metrics -->
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-icon"><i class="fas fa-money-bill-wave"></i></div>
                <div class="metric-label">Total Sales</div>
                <div class="metric-value"><%= (sales.total_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card cash">
                <div class="metric-icon"><i class="fas fa-coins"></i></div>
                <div class="metric-label">Cash Sales</div>
                <div class="metric-value"><%= (sales.cash_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card visa">
                <div class="metric-icon"><i class="fas fa-credit-card"></i></div>
                <div class="metric-label">Visa Sales</div>
                <div class="metric-value"><%= (sales.visa_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card mobile">
                <div class="metric-icon"><i class="fas fa-mobile-alt"></i></div>
                <div class="metric-label">Mobile Money</div>
                <div class="metric-value"><%= (sales.mobile_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card balance">
                <div class="metric-icon"><i class="fas fa-wallet"></i></div>
                <div class="metric-label">Total Balance</div>
                <div class="metric-value"><%= (sales.total_balance || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card expense">
                <div class="metric-icon"><i class="fas fa-arrow-down"></i></div>
                <div class="metric-label">Total Expenses</div>
                <div class="metric-value"><%= (totalExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card before">
                <div class="metric-icon"><i class="fas fa-arrow-up"></i></div>
                <div class="metric-label">Before Expenses</div>
                <div class="metric-value"><%= (beforeExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card after">
                <div class="metric-icon"><i class="fas fa-check-circle"></i></div>
                <div class="metric-label">After Expenses</div>
                <div class="metric-value"><%= (afterExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>
        </div>

        <!-- Expenses for Today -->
        <% if (expenses && expenses.length > 0) { %>
            <div class="report-section">
                <div class="section-header">
                    <h2 class="section-title"><i class="fas fa-clipboard-list"></i> Expenses for Today</h2>
                </div>
                <div class="expense-list">
                    <% expenses.forEach(expense => { %>
                        <div class="expense-item">
                            <div class="expense-item-content">
                                <div class="expense-icon"><i class="fas fa-receipt"></i></div>
                                <div class="expense-details">
                                    <div class="expense-description"><%= expense.category %></div>
                                    <span class="expense-category"><%= expense.category %></span>
                                </div>
                            </div>
                            <div class="expense-amount">
                                <i class="fas fa-minus-circle"></i>
                                <%= parseFloat(expense.amount).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %> UGX
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    <% } %>

    <!-- WEEKLY REPORT -->
    <% if (reportType === 'weekly') { %>
        <!-- Key Metrics (Weekly Totals) -->
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-icon"><i class="fas fa-money-bill-wave"></i></div>
                <div class="metric-label">Total Weekly Sales</div>
                <div class="metric-value"><%= (sales.total_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card cash">
                <div class="metric-icon"><i class="fas fa-coins"></i></div>
                <div class="metric-label">Cash Sales</div>
                <div class="metric-value"><%= (sales.cash_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card visa">
                <div class="metric-icon"><i class="fas fa-credit-card"></i></div>
                <div class="metric-label">Visa Sales</div>
                <div class="metric-value"><%= (sales.visa_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card mobile">
                <div class="metric-icon"><i class="fas fa-mobile-alt"></i></div>
                <div class="metric-label">Mobile Money</div>
                <div class="metric-value"><%= (sales.mobile_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card balance">
                <div class="metric-icon"><i class="fas fa-wallet"></i></div>
                <div class="metric-label">Total Balance</div>
                <div class="metric-value"><%= (sales.total_balance || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card expense">
                <div class="metric-icon"><i class="fas fa-arrow-down"></i></div>
                <div class="metric-label">Total Expenses</div>
                <div class="metric-value"><%= (totalExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card before">
                <div class="metric-icon"><i class="fas fa-arrow-up"></i></div>
                <div class="metric-label">Before Expenses</div>
                <div class="metric-value"><%= (beforeExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card after">
                <div class="metric-icon"><i class="fas fa-check-circle"></i></div>
                <div class="metric-label">After Expenses</div>
                <div class="metric-value"><%= (afterExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>
        </div>

        <!-- Daily Breakdown Table -->
        <% if (dailyBreakdown && dailyBreakdown.length > 0) { %>
            <div class="report-section">
                <div class="section-header">
                    <h2 class="section-title"><i class="fas fa-chart-bar"></i> Daily Breakdown for the Week</h2>
                </div>
                <table class="breakdown-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Total Sales</th>
                            <th>Cash</th>
                            <th>Visa</th>
                            <th>Mobile Money</th>
                            <th>Balance</th>
                            <th>Expenses</th>
                            <th>After Expenses</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% dailyBreakdown.forEach(day => { %>
                            <tr>
                                <td><%= new Date(day.sale_date).toLocaleDateString('en-US', {weekday: 'short', month: 'numeric', day: 'numeric'}) %></td>
                                <td><%= (day.total_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (day.cash_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (day.visa_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (day.mobile_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (day.total_balance || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td style="color: #dc3545; font-weight: 600;"><%= (day.daily_expenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td style="color: #28a745; font-weight: 600;"><%= ((day.total_sales || 0) - (day.daily_expenses || 0)).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    <% } %>

    <!-- MONTHLY REPORT -->
    <% if (reportType === 'monthly') { %>
        <div class="filter-section">
            <label><i class="fas fa-calendar-alt"></i> Month:</label>
            <select onchange="window.location.href='/sales-report/monthly?month=' + this.value + '&year=' + document.getElementById('yearSelect').value;">
                <% months.forEach(month => { %>
                    <option value="<%= month.value %>" <%= month.value === selectedMonth ? 'selected' : '' %>>
                        <%= month.name %>
                    </option>
                <% }) %>
            </select>
            <label style="margin-left: 10px;"><i class="fas fa-hashtag"></i> Year:</label>
            <input type="number" id="yearSelect" value="<%= selectedYear %>" min="2000" max="2099" onchange="window.location.href='/sales-report/monthly?month=' + document.querySelector('select').value + '&year=' + this.value;">
        </div>

        <!-- Key Metrics -->
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-icon"><i class="fas fa-money-bill-wave"></i></div>
                <div class="metric-label">Total Monthly Sales</div>
                <div class="metric-value"><%= (sales.total_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card cash">
                <div class="metric-icon"><i class="fas fa-coins"></i></div>
                <div class="metric-label">Cash Sales</div>
                <div class="metric-value"><%= (sales.cash_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card visa">
                <div class="metric-icon"><i class="fas fa-credit-card"></i></div>
                <div class="metric-label">Visa Sales</div>
                <div class="metric-value"><%= (sales.visa_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card mobile">
                <div class="metric-icon"><i class="fas fa-mobile-alt"></i></div>
                <div class="metric-label">Mobile Money</div>
                <div class="metric-value"><%= (sales.mobile_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card balance">
                <div class="metric-icon"><i class="fas fa-wallet"></i></div>
                <div class="metric-label">Total Balance</div>
                <div class="metric-value"><%= (sales.total_balance || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card expense">
                <div class="metric-icon"><i class="fas fa-arrow-down"></i></div>
                <div class="metric-label">Total Expenses</div>
                <div class="metric-value"><%= (totalExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card before">
                <div class="metric-icon"><i class="fas fa-arrow-up"></i></div>
                <div class="metric-label">Before Expenses</div>
                <div class="metric-value"><%= (beforeExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card after">
                <div class="metric-icon"><i class="fas fa-check-circle"></i></div>
                <div class="metric-label">After Expenses</div>
                <div class="metric-value"><%= (afterExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>
        </div>

        <!-- Daily Breakdown Table -->
        <% if (dailyBreakdown && dailyBreakdown.length > 0) { %>
            <div class="report-section">
                <div class="section-header">
                    <h2 class="section-title"><i class="fas fa-chart-bar"></i> Daily Breakdown for <%= months.find(m => m.value === selectedMonth).name %> <%= selectedYear %></h2>
                </div>
                <table class="breakdown-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Total Sales</th>
                            <th>Cash</th>
                            <th>Visa</th>
                            <th>Mobile Money</th>
                            <th>Balance</th>
                            <th>Expenses</th>
                            <th>After Expenses</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% dailyBreakdown.forEach(day => { %>
                            <tr>
                                <td><%= new Date(day.sale_date).toLocaleDateString('en-US', {weekday: 'short', month: 'numeric', day: 'numeric'}) %></td>
                                <td><%= (day.total_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (day.cash_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (day.visa_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (day.mobile_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (day.total_balance || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td style="color: #dc3545; font-weight: 600;"><%= (day.daily_expenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td style="color: #28a745; font-weight: 600;"><%= ((day.total_sales || 0) - (day.daily_expenses || 0)).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    <% } %>

    <!-- ANNUAL REPORT -->
    <% if (reportType === 'annual') { %>
        <div class="filter-section">
            <label><i class="fas fa-hashtag"></i> Year:</label>
            <input type="number" value="<%= selectedYear %>" min="2000" max="2099" onchange="window.location.href='/sales-report/annual?year=' + this.value;">
        </div>

        <!-- Key Metrics -->
        <div class="metrics-grid">
            <div class="metric-card">
                <div class="metric-icon"><i class="fas fa-money-bill-wave"></i></div>
                <div class="metric-label">Total Annual Sales</div>
                <div class="metric-value"><%= (sales.total_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card cash">
                <div class="metric-icon"><i class="fas fa-coins"></i></div>
                <div class="metric-label">Cash Sales</div>
                <div class="metric-value"><%= (sales.cash_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card visa">
                <div class="metric-icon"><i class="fas fa-credit-card"></i></div>
                <div class="metric-label">Visa Sales</div>
                <div class="metric-value"><%= (sales.visa_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card mobile">
                <div class="metric-icon"><i class="fas fa-mobile-alt"></i></div>
                <div class="metric-label">Mobile Money</div>
                <div class="metric-value"><%= (sales.mobile_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card balance">
                <div class="metric-icon"><i class="fas fa-wallet"></i></div>
                <div class="metric-label">Total Balance</div>
                <div class="metric-value"><%= (sales.total_balance || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card expense">
                <div class="metric-icon"><i class="fas fa-arrow-down"></i></div>
                <div class="metric-label">Total Expenses</div>
                <div class="metric-value"><%= (totalExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card before">
                <div class="metric-icon"><i class="fas fa-arrow-up"></i></div>
                <div class="metric-label">Before Expenses</div>
                <div class="metric-value"><%= (beforeExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>

            <div class="metric-card after">
                <div class="metric-icon"><i class="fas fa-check-circle"></i></div>
                <div class="metric-label">After Expenses</div>
                <div class="metric-value"><%= (afterExpenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></div>
                <div class="metric-currency">UGX</div>
            </div>
        </div>

        <!-- Monthly Breakdown Table -->
        <% if (monthlyBreakdown && monthlyBreakdown.length > 0) { %>
            <div class="report-section">
                <div class="section-header">
                    <h2 class="section-title"><i class="fas fa-chart-bar"></i> Monthly Breakdown for <%= selectedYear %></h2>
                </div>
                <table class="breakdown-table">
                    <thead>
                        <tr>
                            <th>Month</th>
                            <th>Total Sales</th>
                            <th>Cash</th>
                            <th>Visa</th>
                            <th>Mobile Money</th>
                            <th>Balance</th>
                            <th>Expenses</th>
                            <th>After Expenses</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% monthlyBreakdown.forEach(month => { %>
                            <tr>
                                <td><%= new Date(2024, month.month - 1).toLocaleDateString('en-US', {month: 'long'}) %></td>
                                <td><%= (month.total_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (month.cash_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (month.visa_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (month.mobile_sales || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td><%= (month.total_balance || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td style="color: #dc3545; font-weight: 600;"><%= (month.monthly_expenses || 0).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                                <td style="color: #28a745; font-weight: 600;"><%= ((month.total_sales || 0) - (month.monthly_expenses || 0)).toLocaleString('en-US', {minimumFractionDigits: 0, maximumFractionDigits: 0}) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    <% } %>
</div>
