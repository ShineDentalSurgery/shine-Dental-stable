<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Create Invoice</title>

<style>

body{
    font-family: Arial, sans-serif;
    background:#f4f4f4;
    padding:20px;
}

.container{
    max-width:800px;
    margin:auto;
    background:white;
    padding:30px;
    border-radius:6px;
    box-shadow:0 0 10px rgba(0,0,0,0.1);
}

h2{
    text-align:center;
}

.section-title{
    font-size:18px;
    font-weight:bold;
    margin-top:20px;
    border-bottom:2px solid #eee;
    padding-bottom:5px;
}

label{
    font-weight:bold;
    margin-top:10px;
}

input,textarea{
    width:100%;
    padding:8px;
    margin-top:5px;
    border:1px solid #ccc;
    border-radius:4px;
}

.grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:15px;
}

.item-entry{
    background:#f9f9f9;
    border-left:4px solid #007bff;
    padding:15px;
    margin-top:10px;
}

.item-grid{
    display:grid;
    grid-template-columns:2fr 1fr 1fr 1fr 1fr;
    gap:10px;
}

button{
    padding:10px;
    border:none;
    border-radius:4px;
    cursor:pointer;
    margin-top:10px;
}

.add-item-btn{
    background:#28a745;
    color:white;
}

.remove-item{
    background:#dc3545;
    color:white;
}

.submit-btn{
    background:#007bff;
    color:white;
    width:100%;
    font-weight:bold;
    margin-top:20px;
}

.total-box{
    margin-top:20px;
    text-align:right;
}

.total-box input{
    width:200px;
}

</style>
</head>

<body>

<div class="container">

<h2>Create New Invoice</h2>

<form id="invoiceForm" action="/invoices/create" method="POST">

<!-- CLIENT -->
<div class="section-title">Client Information</div>

<div class="grid">

<div>
<label>Client Name</label>
<input type="text" name="client_name" required>
</div>

<div>
<label>Phone</label>
<input type="text" name="client_tel" required>
</div>

<div style="grid-column:1/3">
<label>Address</label>
<textarea name="client_address"></textarea>
</div>

</div>


<!-- INVOICE -->
<div class="section-title">Invoice Information</div>

<div class="grid">

<div>
<label>Date</label>
<input type="date" name="invoice_date" required>
</div>

<!-- LPO removed -->

</div>


<!-- ITEMS -->
<div class="section-title">Invoice Items</div>

<div id="itemsContainer"></div>

<button type="button" class="add-item-btn" onclick="addItem()">+ Add Item</button>


<!-- TOTAL -->
<div class="total-box">

<label>Total Amount (UGX)</label><br>
<input type="number" id="total" name="total" readonly>

</div>

<input type="hidden" id="items" name="items">

<button type="submit" class="submit-btn">Create Invoice</button>

</form>

</div>


<script>

let itemCount=0;

function addItem(){

itemCount++;

const html=`

<div class="item-entry" data-id="${itemCount}">

<div class="item-grid">

<div>
<label>Item Name</label>
<input type="text" class="item-name" required>
</div>

<div>
<label>Qty</label>
<input type="number" class="item-qty" value="1" min="1">
</div>

<div>
<label>Unit</label>
<input type="text" class="item-unit" placeholder="Piece">
</div>

<div>
<label>Unit Price</label>
<input type="number" class="item-price" value="0">
</div>

<div>
<label>Amount</label>
<input type="number" class="item-amount" readonly>
</div>

</div>

<button type="button" class="remove-item" onclick="removeItem(${itemCount})">Remove</button>

</div>
`;

document.getElementById("itemsContainer").insertAdjacentHTML("beforeend",html);

const newEntry = document.querySelector(`[data-id="${itemCount}"]`);
newEntry.querySelector(".item-qty").addEventListener("input", calculateTotal);
newEntry.querySelector(".item-price").addEventListener("input", calculateTotal);

calculateTotal();

}


function removeItem(id){

const el=document.querySelector('[data-id="'+id+'"]');

if(el) el.remove();

calculateTotal();

}


function calculateTotal(){

let total=0;
const items=[];

document.querySelectorAll(".item-entry").forEach(entry=>{

const name=entry.querySelector(".item-name").value;

const qty=parseFloat(entry.querySelector(".item-qty").value)||0;

const unit=entry.querySelector(".item-unit").value;

const price=parseFloat(entry.querySelector(".item-price").value)||0;

const amount=qty*price;

entry.querySelector(".item-amount").value=amount;

items.push({
item_name:name,
qty:qty,
unit:unit,
unit_price:price,
amount:amount
});

total+=amount;

});

document.getElementById("total").value=total;

document.getElementById("items").value=JSON.stringify(items);

}


window.onload=function(){
addItem();
}

</script>

</body>
</html>